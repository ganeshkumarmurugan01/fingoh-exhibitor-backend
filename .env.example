# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Supabase ──────────────────────────────────────────────────────
# Found in: Supabase dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...   # service_role key — backend only, never expose to frontend
SUPABASE_JWT_SECRET=your-jwt-secret

# ── App ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173  # update to your Vercel URL in production
APP_ENV=development
DEBUG=true
